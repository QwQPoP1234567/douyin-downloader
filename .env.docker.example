# 复制为 .env 后修改。不要提交包含真实密码和钉钉密钥的 .env。
TZ=Asia/Shanghai

# 群晖建议使用 /volume1/docker/douyin 下的持久目录。
DOUYIN_DATA_PATH=/volume1/docker/douyin/data
DOUYIN_DOWNLOAD_PATH=/volume1/docker/douyin/downloads
DOUYIN_BROWSER_PATH=/volume1/docker/douyin/browser_data

DOUYIN_WEB_PORT=8765
DOUYIN_NOVNC_PORT=6080
DOUYIN_VNC_PASSWORD=请替换为强密码
DOUYIN_LINUX_NOVNC_ENABLED=true
DOUYIN_LINUX_NOVNC_MODE=on_demand
DOUYIN_LINUX_NOVNC_IDLE_SECONDS=120
DOUYIN_LINUX_VNC_POLL_MS=80
DOUYIN_LINUX_VNC_DEFER_MS=80
DOUYIN_DOWNLOAD_CONCURRENCY=2

DOUYIN_DINGTALK_ENABLED=false
DOUYIN_DINGTALK_WEBHOOK=
DOUYIN_DINGTALK_SECRET=
